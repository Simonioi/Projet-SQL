-- Sélectionne toutes les colonnes de la table vehicule
SELECT * FROM vehicule;
-- Filtre les véhicules dont l'état est marqué comme disponible
SELECT * FROM vehicule 
WHERE etat = 'disponible';
-- Sélectionne les véhicules localisés à Paris
SELECT id_vehicule, marque, modele, type_vehicule 
FROM vehicule 
WHERE ville = 'Paris';
-- Liste les véhicules longue distance (autonomie > 400km)
SELECT marque, modele, autonomie_km 
FROM vehicule 
WHERE autonomie_km > 400 
ORDER BY autonomie_km DESC; -- Bonus : trié du plus autonome au moins autonome

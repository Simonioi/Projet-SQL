-- Afficher les locations avec le nom et le prénom de chaque client
SELECT l.id_location, l.date_debut, l.date_fin, c.nom, c.prenom
FROM location l
JOIN client c ON l.id_client = c.id_client;

-- Lister les locations en précisant la marque et le modèle du véhicule
SELECT l.id_location, l.date_debut, l.date_fin, v.marque, v.modele
FROM location l
JOIN vehicule v ON l.id_vehicule = v.id_vehicule;

-- Afficher le nom des stations de départ et d'arrivée pour chaque trajet
SELECT l.id_location, sd.nom AS station_depart, sa.nom AS station_arrivee
FROM location l
JOIN station sd ON l.id_station_depart = sd.id_station
JOIN station sa ON l.id_station_arrivee = sa.id_station;
